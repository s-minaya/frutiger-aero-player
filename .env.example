# ─── Copia este archivo como .env.local ───────────────────────────────────────
# .env.local está en .gitignore y NUNCA debe subirse al repositorio.
#
# Para deploy (GitHub Pages, Vercel, Netlify, etc.) añade estas mismas
# variables como secrets/env vars en el panel de configuración del servicio
# o en GitHub Actions → Settings → Secrets and variables → Actions.

# ─── Spotify ──────────────────────────────────────────────────────────────────

# ID de tu aplicación en el Dashboard de Spotify
# https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=tu_client_id_aqui

# URI de redirección registrada en el Dashboard de Spotify.
# IMPORTANTE: usa 127.0.0.1, no localhost — Spotify los trata como distintos
# En desarrollo: http://127.0.0.1:5173/spotify-frutiger-aero/callback
# En producción: https://tu-usuario.github.io/spotify-frutiger-aero/callback
VITE_REDIRECT_URI=http://127.0.0.1:5173/spotify-frutiger-aero/callback

# ─── MSW (Mock Service Worker) ────────────────────────────────────────────────

# Activa MSW para interceptar llamadas a Spotify con datos de prueba.
# Solo se usa en tests E2E — no tocar en desarrollo normal.
# El servidor E2E lo activa automáticamente via playwright.config.js
# VITE_MSW=true
